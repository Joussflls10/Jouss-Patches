# Morphe Workspace Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# Kaggle API token (for remote jadx decompilation)
# Get from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_API_TOKEN=

# Kaggle kernel ID (your-username/notebook-name)
# Create a private notebook on Kaggle called "jadx-apk-decompiler"
KAGGLE_KERNEL_ID=your-username/jadx-apk-decompiler

# GitHub PAT (for gradle dependency resolution)
# Needs: read:packages scope
# Also add to ~/.gradle/gradle.properties as gpr.user and gpr.key
GITHUB_TOKEN=
