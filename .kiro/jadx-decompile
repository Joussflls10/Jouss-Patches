#!/bin/bash
# jadx-decompile — Single-file APK decompiler via Kaggle
# Usage: ./jadx-decompile "https://apk-download-url"
# Requirements: kaggle CLI + KAGGLE_API_TOKEN env var

set -e

# Load .env if exists
if [ -f "$(dirname "$0")/../.env" ]; then
    set -a; source "$(dirname "$0")/../.env"; set +a
fi

APK_URL="${1:?Usage: ./jadx-decompile <APK_URL> [output-dir]}"
OUTPUT_DIR="${2:-./output}"

# Validate URL
if [[ ! "$APK_URL" =~ ^https?:// ]]; then
    echo "❌ Error: First argument must be a URL (https://...)"
    echo "Usage: ./jadx-decompile \"https://direct-download-url\" [output-dir]"
    exit 1
fi

KERNEL_ID="${KAGGLE_KERNEL_ID:-your-username/jadx-apk-decompiler}"

# Create output dir if needed
mkdir -p "$OUTPUT_DIR"

WORK_DIR=$(mktemp -d)
trap "rm -rf $WORK_DIR" EXIT

echo "============================================================"
echo "📦 JADX Remote Decompiler (Kaggle)"
echo "============================================================"
echo "URL: ${APK_URL:0:80}..."
echo ""

export KAGGLE_API_TOKEN="${KAGGLE_API_TOKEN:?Error: KAGGLE_API_TOKEN not set. Add it to .env or export it.}"

# Generate notebook inline
APK_URL="$APK_URL" WORK_DIR="$WORK_DIR" python3 << 'PYSCRIPT'
import json, os

apk_url = os.environ["APK_URL"]
work_dir = os.environ["WORK_DIR"]

nb = {
 'nbformat': 4, 'nbformat_minor': 4,
 'metadata': {'kernelspec': {'display_name': 'Python 3', 'language': 'python', 'name': 'python3'}},
 'cells': [
  {'cell_type': 'code', 'metadata': {}, 'source': [
    'import os\n',
    f'APK_URL = {repr(apk_url)}\n',
    'print(f"URL: {APK_URL[:80]}...")\n',
  ], 'outputs': [], 'execution_count': None},

  {'cell_type': 'code', 'metadata': {}, 'source': [
    '%%bash\n',
    'apt-get update -qq && apt-get install -y -qq default-jre-headless aria2 > /dev/null 2>&1\n',
    'JADX_VER="1.5.5"\n',
    'wget -q "https://github.com/skylot/jadx/releases/download/v${JADX_VER}/jadx-${JADX_VER}.zip" -O /tmp/jadx.zip\n',
    'unzip -qo /tmp/jadx.zip -d /opt/jadx && chmod +x /opt/jadx/bin/jadx && ln -sf /opt/jadx/bin/jadx /usr/local/bin/jadx\n',
    'echo "JADX $(jadx --version) installed"',
  ], 'outputs': [], 'execution_count': None},

  {'cell_type': 'code', 'metadata': {}, 'source': [
    'import os, re, base64, shutil, subprocess\n',
    'from urllib.parse import urlparse, parse_qs, unquote\n',
    'from pathlib import Path\n',
    'def detect_filename(url):\n',
    '    parsed = urlparse(url)\n',
    '    params = parse_qs(parsed.query)\n',
    '    for key in ("_fn", "filename", "file"):\n',
    '        if key in params:\n',
    '            name = unquote(params[key][0])\n',
    '            try:\n',
    '                decoded = base64.b64decode(name + "=" * (-len(name) % 4)).decode()\n',
    '                if "." in decoded: return decoded\n',
    '            except Exception: pass\n',
    '            if "." in name: return name\n',
    '    name = Path(parsed.path).name\n',
    '    return name if name else "downloaded_file"\n',
    'def sanitize(name):\n',
    '    stem = Path(name).stem\n',
    '    ext = Path(name).suffix.lower()\n',
    '    m = re.match(r"([a-z][a-z0-9._]+?)_([0-9][0-9.]+)", stem, re.IGNORECASE)\n',
    '    if m: return f"{m.group(1)}_{m.group(2)}{ext}"\n',
    '    clean = re.sub(r"[^a-z0-9._-]", "_", stem.lower())\n',
    '    clean = re.sub(r"_+", "_", clean).strip("_")[:60]\n',
    '    return clean + ext\n',
    'apk_file = sanitize(detect_filename(APK_URL))\n',
    'print(f"Downloading: {apk_file}")\n',
    '!aria2c -x 16 -s 16 -k 1M --file-allocation=none --disk-cache=64M -o "{apk_file}" "{APK_URL}"\n',
    'print(f"Saved: {apk_file} ({os.path.getsize(apk_file)/1024/1024:.1f} MB)")\n',
  ], 'outputs': [], 'execution_count': None},

  {'cell_type': 'code', 'metadata': {}, 'source': [
    'import zipfile\n',
    'target = apk_file\n',
    'ext = Path(apk_file).suffix.lower()\n',
    'if ext in (".xapk", ".apkm", ".apks", ".zip"):\n',
    '    print(f"Split APK ({ext}), extracting...")\n',
    '    extract_dir = Path(apk_file).stem + "_extracted"\n',
    '    with zipfile.ZipFile(apk_file, "r") as z:\n',
    '        z.extractall(extract_dir)\n',
    '        contents = z.namelist()\n',
    '    apk_list = [f for f in contents if f.endswith(".apk")]\n',
    '    for a in apk_list:\n',
    '        s = os.path.getsize(os.path.join(extract_dir, a)) / 1024 / 1024\n',
    '        tag = " base" if "base" in a.lower() else ""\n',
    '        print(f"  {s:8.1f} MB  {a}{tag}")\n',
    '    base = next((f for f in apk_list if "base" in f.lower()), None)\n',
    '    if base: target = os.path.join(extract_dir, base)\n',
    '    elif apk_list: target = max([os.path.join(extract_dir, f) for f in apk_list], key=os.path.getsize)\n',
    '    print(f"Using: {target}")\n',
    'else:\n',
    '    print(f"Direct APK: {target}")\n',
  ], 'outputs': [], 'execution_count': None},

  {'cell_type': 'code', 'metadata': {}, 'source': [
    'output_dir = Path(apk_file).stem + "_decompiled"\n',
    'cores = os.cpu_count() or 4\n',
    'os.environ["JADX_JAVA_OPTS"] = f"-Xmx28672m -Xms14336m -XX:+UseParallelGC -XX:ParallelGCThreads={cores} -XX:+OptimizeStringConcat -XX:+UseStringDeduplication"\n',
    'print(f"RAM: 28GB | Threads: {cores}")\n',
    '!jadx -d "{output_dir}" --deobf --show-bad-code --decompilation-mode restructure --log-level progress -j {cores} -Pdex-input.verify-checksum=no -Pkotlin-metadata.class-alias=yes -Pkotlin-metadata.method-args=yes -Pkotlin-metadata.fields=yes -Pkotlin-metadata.data-class=yes -Pkotlin-metadata.to-string=yes -Pkotlin-metadata.getters=yes --use-source-name-as-class-name-alias always --use-kotlin-methods-for-var-names apply-and-hide --rename-flags all "{target}" 2>&1\n',
    'java_count = int(os.popen(f\'find "{output_dir}" -name "*.java" | wc -l\').read().strip())\n',
    'total_count = int(os.popen(f\'find "{output_dir}" -type f | wc -l\').read().strip())\n',
    'print(f"{java_count:,} .java | {total_count:,} total files")\n',
  ], 'outputs': [], 'execution_count': None},

  {'cell_type': 'code', 'metadata': {}, 'source': [
    'import zipfile as zf\n',
    'zip_name = output_dir + ".zip"\n',
    'print(f"Compressing {zip_name}...")\n',
    'fc = 0\n',
    'with zf.ZipFile(zip_name, "w", zf.ZIP_DEFLATED, compresslevel=9) as z:\n',
    '    for root, dirs, files in os.walk(output_dir):\n',
    '        for f in files:\n',
    '            fpath = os.path.join(root, f)\n',
    '            z.write(fpath, os.path.relpath(fpath, output_dir))\n',
    '            fc += 1\n',
    '            if fc % 5000 == 0: print(f"  {fc:,} files...")\n',
    'print(f"{zip_name} ({os.path.getsize(zip_name)/1024/1024:.1f} MB) — {fc:,} files")\n',
    'shutil.rmtree(output_dir, ignore_errors=True)\n',
    'if os.path.exists(apk_file): os.remove(apk_file)\n',
    'extract = Path(apk_file).stem + "_extracted"\n',
    'if os.path.exists(extract): shutil.rmtree(extract, ignore_errors=True)\n',
    'print("Done")\n',
  ], 'outputs': [], 'execution_count': None},
 ]
}

with open(f'{work_dir}/jadx-decompiler.ipynb', 'w') as f:
    json.dump(nb, f)
PYSCRIPT

# Generate metadata
cat > "$WORK_DIR/kernel-metadata.json" << METADATA
{
  "id": "$KERNEL_ID",
  "title": "jadx-apk-decompiler",
  "code_file": "jadx-decompiler.ipynb",
  "language": "python",
  "kernel_type": "notebook",
  "is_private": true,
  "enable_gpu": false,
  "enable_internet": true
}
METADATA

# Push
echo "🚀 Pushing to Kaggle..."
kaggle kernels push -p "$WORK_DIR"
echo ""

# Wait
echo "⏳ Waiting for kernel to finish..."
while true; do
    RAW=$(kaggle kernels status "$KERNEL_ID" 2>&1)
    echo "  $(date +%H:%M:%S) $RAW"
    if echo "$RAW" | grep -qi "complete"; then
        echo "✅ Kernel completed!"
        break
    elif echo "$RAW" | grep -qi "error\|cancel\|fail"; then
        echo "❌ Kernel failed!"
        exit 1
    fi
    sleep 3
done

echo ""

# Download zip only
echo "⬇️  Downloading output..."
mkdir -p "$OUTPUT_DIR"
kaggle kernels output "$KERNEL_ID" -p "$OUTPUT_DIR" --file-pattern ".*\.zip$"
echo ""

echo "============================================================"
echo "✅ Done! Files in: $OUTPUT_DIR/"
echo "============================================================"
ls -lh "$OUTPUT_DIR"/*.zip 2>/dev/null
